# OpenAI — story generation + image generation (gpt-image-2)
OPENAI_API_KEY=

# ElevenLabs — voice synthesis
ELEVENLABS_API_KEY=

# One ElevenLabs Conversational AI agent per archetype.
# Create the 5 agents in the ElevenLabs dashboard, then paste the IDs here.
ELEVENLABS_AGENT_VC=
ELEVENLABS_AGENT_COFOUNDER=
ELEVENLABS_AGENT_REPORTER=
ELEVENLABS_AGENT_HATER=
ELEVENLABS_AGENT_MENTOR=

# Neon Postgres — playthrough capture
# Get the pooled connection string from console.neon.tech
DATABASE_URL=

# Stripe — paywall (test mode only)
# Both keys are required. Publishable is exposed to the client; secret stays
# server-side and is used by /api/paywall/checkout and /api/paywall/verify.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Resend — email OTP for returning-user redemption
# Sign up at resend.com, create an API key. RESEND_FROM defaults to
# 'onboarding@resend.dev' which only sends to the address that owns the
# Resend account; verify a domain to send to anyone.
RESEND_API_KEY=
RESEND_FROM=

# iron-session — encrypts the rsf_session cookie for past-playthrough login.
# Must be ≥32 chars. Generate with: openssl rand -base64 48
RTSF_SESSION_SECRET=
